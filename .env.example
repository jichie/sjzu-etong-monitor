# ========================================
# 山东建筑大学 电费监控服务 - 配置模板
# ========================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填入你的真实配置
#   3. .env 已在 .gitignore 中，不会被提交到 Git
# ========================================

# --- 登录账号（必填）---
SSO_USERNAME=你的学号
SSO_PASSWORD=你的SSO密码

# --- 房间配置（必填）---
BUILDING_NAME=梅二-照明        # 楼栋名称，如"梅二-照明"、"1号楼"
ROOM_NAME=413                  # 房间号

# --- 认证 Token（二选一）---
# 方式一：留空自动获取（推荐）
CTTICKET=
# 方式二：从浏览器手动抓取（教程见 README）
# CTTICKET=web_xxxxxxxxxxxxxxxxxxxx_webreq

# --- 推送通知（至少配置一个）---
WECOM_WEBHOOK=                 # 企业微信机器人 Webhook URL
BARK_KEY=                      # Bark 推送地址（iOS）
PUSHPLUS_TOKEN=                # PushPlus Token

# --- 监控选项（可选，有默认值）---
LOW_BALANCE_THRESHOLD=10       # 低电量告警阈值（度），默认 10
CHECK_INTERVAL=3600            # 检查间隔（秒），默认 3600（1小时）
DAILY_REPORT_HOUR=19           # 日报推送小时，默认 19
DAILY_REPORT_MINUTE=10         # 日报推送分钟，默认 10
ALERT_COOLDOWN=21600           # 告警冷却时间（秒），默认 21600（6小时）

# --- 二次验证（可选）---
SMS_SERVER_PORT=8899           # 验证码接收服务端口，默认 8899
SMS_CODE_TIMEOUT=300           # 验证码等待超时（秒），默认 300（5分钟）
